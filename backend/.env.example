# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=metal_marketplace

# --- JWT / Auth ---
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TTL=900          # access token lifetime, seconds (15 min)
REFRESH_TTL=604800      # refresh token lifetime, seconds (7 days)

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=your-account-id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=metal-marketplace-models

# --- Modal (cloud inference fallback) ---
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
MODAL_APP_NAME=metal-llm-fallback

# --- Misc ---
DOWNLOAD_URL_TTL=300    # presigned GET lifetime, seconds (5 min)
UPLOAD_URL_TTL=900      # presigned PUT lifetime, seconds (15 min)
MAX_DEVICES_DEFAULT=3
RATE_LIMIT_PER_MINUTE=120
